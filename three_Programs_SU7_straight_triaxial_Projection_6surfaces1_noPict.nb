Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"suNBasis", "[", "N_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"basis", "=", 
        RowBox[{"{", "}"}]}], ",", "k", ",", "l", ",", "h", ",", "normed"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"basis", ",", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"k", ",", "l"}], "}"}], "->", "1"}], ",", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"l", ",", "k"}], "}"}], "->", "1"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"N", ",", "N"}], "}"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "N"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"l", ",", 
          RowBox[{"k", "+", "1"}], ",", "N"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"basis", ",", 
          RowBox[{"SparseArray", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"k", ",", "l"}], "}"}], "->", "I"}], ",", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"l", ",", "k"}], "}"}], "->", 
               RowBox[{"-", "I"}]}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"N", ",", "N"}], "}"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "N"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"l", ",", 
          RowBox[{"k", "+", "1"}], ",", "N"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"AppendTo", "[", 
         RowBox[{"basis", ",", 
          RowBox[{"DiagonalMatrix", "[", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"Table", "[", 
              RowBox[{"1", ",", 
               RowBox[{"{", "h", "}"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"-", "h"}], "}"}], ",", 
             RowBox[{"Table", "[", 
              RowBox[{"0", ",", 
               RowBox[{"{", 
                RowBox[{"N", "-", "h", "-", "1"}], "}"}]}], "]"}]}], "]"}], 
           "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"h", ",", "1", ",", 
          RowBox[{"N", "-", "1"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"normed", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Tr", "[", 
             RowBox[{"#", ".", "#"}], "]"}], "]"}]}], "&"}], ",", "basis"}], 
        "]"}]}], ";", "\[IndentingNewLine]", "normed"}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.960330466511712*^9, 3.960330500019874*^9}},
 CellLabel->"In[63]:=",ExpressionUUID->"ae9874cd-df85-4021-a330-8ef249cf4acc"],

