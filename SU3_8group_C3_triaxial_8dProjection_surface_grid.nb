     RowBox[{"Cos", "[", 
      RowBox[{
       FractionBox["\[Pi]", "6"], "-", "t"}], "]"}], " ", 
     RowBox[{"Sin", "[", "t", "]"}]}], "-", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", 
      RowBox[{
       FractionBox["\[Pi]", "6"], "+", "t"}], "]"}], " ", 
     RowBox[{"Sin", "[", "t", "]"}]}], "-", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Cos", "[", 
      RowBox[{
       FractionBox["\[Pi]", "6"], "-", "t"}], "]"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{
       FractionBox["\[Pi]", "6"], "+", "t"}], "]"}]}], "+", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", 
     SuperscriptBox["r", "2"], " ", 
     RowBox[{"Sin", "[", "p", "]"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{
       FractionBox["\[Pi]", "6"], "+", "t"}], "]"}]}]}]}], "}"}]], "Output",
