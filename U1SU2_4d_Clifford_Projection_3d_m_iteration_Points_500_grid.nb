                 RowBox[{"[", 
                  RowBox[{"i", ",", "j", ",", 
                   RowBox[{"k", "-", "1"}]}], "]"}], "]"}]}], "}"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"MemberQ", "[", 
                RowBox[{"nbrs", ",", "False"}], "]"}], ",", 
