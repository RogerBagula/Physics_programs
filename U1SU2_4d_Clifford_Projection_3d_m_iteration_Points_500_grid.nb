     RowBox[{"(", 
      RowBox[{"nz", "-", "1"}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"inside", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"False", ",", 
      RowBox[{"{", "nx", "}"}], ",", 
      RowBox[{"{", "ny", "}"}], ",", 
      RowBox[{"{", "nz", "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x0", "=", 
         RowBox[{"xmin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}], "*", "dx"}]}]}], ",", 
        RowBox[{"y0", "=", 
         RowBox[{"ymin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"j", "-", "1"}], ")"}], "*", "dy"}]}]}], ",", 
        RowBox[{"z0", "=", 
         RowBox[{"zmin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"k", "-", "1"}], ")"}], "*", "dz"}]}]}], ",", "it"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"it", "=", 
        RowBox[{"escapeTime3D", "[", 
         RowBox[{"x0", ",", "y0", ",", "z0", ",", "maxIter"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"it", "==", "maxIter"}], ",", 
         RowBox[{
          RowBox[{"inside", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "j", ",", "k"}], "]"}], "]"}], "=", "True"}]}], 
        "]"}], ";"}]}], "]"}], ",", 
    RowBox[{"{", 
