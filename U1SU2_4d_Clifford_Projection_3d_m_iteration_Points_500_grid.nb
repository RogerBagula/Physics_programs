 RowBox[{
  RowBox[{
   RowBox[{"maxIter", "=", "40"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"nx", "=", 
   RowBox[{"ny", "=", 
    RowBox[{"nz", "=", "500"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xmin", "=", 
   RowBox[{"ymin", "=", 
    RowBox[{"zmin", "=", 
     RowBox[{"-", "1.5"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xmax", "=", 
    RowBox[{"ymax", "=", 
     RowBox[{"zmax", "=", "1.5"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"dx", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"xmax", "-", "xmin"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"nx", "-", "1"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dy", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"ymax", "-", "ymin"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"ny", "-", "1"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"dz", "=", 
